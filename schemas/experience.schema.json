{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experience Schema",
  "type": "object",
  "required": ["id", "problem", "solution", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^exp_"
    },
    "project_id": {
      "type": "string",
      "pattern": "^proj_"
    },
    "problem": {
      "type": "object",
      "required": ["title", "symptoms"],
      "properties": {
        "title": {"type": "string"},
        "symptoms": {"type": "array", "items": {"type": "string"}},
        "error_signatures": {"type": "array", "items": {"type": "string"}}
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "where": {"type": "string"},
        "conditions": {"type": "array", "items": {"type": "string"}},
        "related_tasks": {"type": "array", "items": {"type": "string", "pattern": "^task_"}}
      }
    },
    "solution": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "steps": {"type": "array", "items": {"type": "string"}},
        "patch_hint": {"type": "string"},
        "validation": {"type": "array", "items": {"type": "string"}}
      }
    },
    "reusable_pattern": {
      "type": "object",
      "properties": {
        "when_to_apply": {"type": "string"},
        "template": {"type": "string"}
      }
    },
    "contributor": {
      "type": "object",
      "properties": {
        "worker_id": {"type": "string"},
        "credited_xp": {"type": "integer"}
      }
    },
    "reuse": {
      "type": "object",
      "properties": {
        "count": {"type": "integer", "minimum": 0},
        "reused_by_workers": {"type": "array", "items": {"type": "string"}}
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
