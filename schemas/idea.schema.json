{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Idea Schema",
  "type": "object",
  "required": ["id", "title", "status", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^idea_"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "value_hypothesis": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "status": {
      "type": "string",
      "enum": ["new", "triaged", "parked", "converted"]
    },
    "links": {
      "type": "object",
      "properties": {
        "related_projects": {
          "type": "array",
          "items": {"type": "string", "pattern": "^proj_"}
        },
        "references": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "created_by": {
      "type": "string",
      "enum": ["human", "planner"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
